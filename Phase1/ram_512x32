module ram_512x32 (
    input clk,
    input read,
    input write,
    input [8:0] address,
    input [31:0] data_in,
    output reg [31:0] data_out
);

    reg [31:0] memory [0:511];

    always @(posedge clk) begin
        if (write)
            memory[address] <= data_in;
            
        if (read)
            data_out <= memory[address];
    end

endmodule
